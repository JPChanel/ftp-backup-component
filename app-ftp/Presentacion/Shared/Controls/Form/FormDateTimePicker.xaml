<UserControl x:Class="app_ftp.Presentacion.Shared.Controls.Form.FormDateTimePicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    
    <StackPanel Orientation="Vertical">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <!-- DatePicker -->
            <DatePicker x:Name="DatePickerControl"
                        Grid.Column="0"
                        Style="{StaticResource AppFloatingDatePicker}"
                        FontSize="13"
                        materialDesign:HintAssist.Hint="{Binding DisplayLabel, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        SelectedDate="{Binding DateValue, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}"
                        SelectedDateChanged="DatePickerControl_SelectedDateChanged"
                        DateValidationError="DatePickerControl_DateValidationError"
                        IsEnabled="{Binding IsEnabled, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
            
            <!-- TimePicker -->
            <materialDesign:TimePicker x:Name="TimePickerControl"
                                       Grid.Column="2"
                                       Style="{StaticResource AppFloatingTimePicker}"
                                       FontSize="13"
                                       materialDesign:HintAssist.Hint="Hora"
                                       Width="80"
                                       Is24Hours="True"
                                       SelectedTime="{Binding TimeValue, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}"
                                       IsEnabled="{Binding IsEnabled, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
        </Grid>
        <TextBlock Margin="0,4,0,0"
                   Foreground="#DC2626"
                   FontSize="11"
                   Text="{Binding ValidationMessage, RelativeSource={RelativeSource AncestorType=UserControl}}"
                   Visibility="{Binding HasValidationError, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}"/>
    </StackPanel>
</UserControl>

