<UserControl x:Class="app_ftp.Presentacion.Shared.Controls.WeightDisplay.WeightDisplayControl"
             x:Name="RootControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:form="clr-namespace:app_ftp.Presentacion.Shared.Controls.Form"
             mc:Ignorable="d" 
             d:DesignHeight="200" d:DesignWidth="250">
    
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        
        <!-- Estilo para el Display de Peso Digital -->
        <Style x:Key="WeightDisplay" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontFamily" Value="Consolas"/>
        </Style>
    </UserControl.Resources>

    <Border x:Name="RootBorder"
            Background="{DynamicResource MaterialDesignCardBackground}" 
            BorderThickness="2"
            CornerRadius="8" 
            Padding="12"
            VerticalAlignment="Top">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="BorderBrush" Value="{Binding ElementName=RootControl, Path=ColorBorde}"/>
                <Style.Triggers>
                    <!-- Cambiar borde a rojo si no estÃ¡ conectada -->
                    <DataTrigger Binding="{Binding ElementName=RootControl, Path=Conectada}" Value="False">
                        <Setter Property="BorderBrush" Value="#EF4444"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        
        <Border.Effect>
            <DropShadowEffect BlurRadius="6" ShadowDepth="2" Opacity="0.1" Color="#000000"/>
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Display de Peso -->
            <Border Grid.Row="0"
                    Background="{DynamicResource MaterialDesignTextFieldBoxBackground}"
                    BorderBrush="{DynamicResource MaterialDesignDivider}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="16,12"
                    Margin="0,0,0,6">
                <TextBlock Style="{StaticResource WeightDisplay}"
                           Text="{Binding ElementName=RootControl, Path=PesoActual, StringFormat='0.00', TargetNullValue='0.00'}">
                    <TextBlock.Foreground>
                        <SolidColorBrush Color="{Binding ElementName=RootControl, Path=ColorBorde}"/>
                    </TextBlock.Foreground>
                </TextBlock>
            </Border>

            <!-- BotÃ³n de Captura con indicador de estabilidad -->
            <Grid Grid.Row="1">
                <form:CustomButton Command="{Binding ElementName=RootControl, Path=CapturarCommand}"
                                   Variant="Custom" 
                                   Height="38" 
                                   IconKind="Camera" 
                                   Margin="0"
                                   VerticalAlignment="Top"
                                   Visibility="{Binding ElementName=RootControl, Path=MostrarBotonCaptura, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <form:CustomButton.BackgroundColor>
                        <SolidColorBrush Color="{Binding ElementName=RootControl, Path=ColorBorde}"/>
                    </form:CustomButton.BackgroundColor>
                    <form:CustomButton.Text>
                        <MultiBinding StringFormat="Capturar {0}">
                            <Binding ElementName="RootControl" Path="BalanzaNombre"/>
                        </MultiBinding>
                    </form:CustomButton.Text>
                    <form:CustomButton.Style>
                        <Style TargetType="form:CustomButton">
                            <Setter Property="IsEnabled" Value="True"/>
                            <Style.Triggers>
                                <!-- Cuando estÃ¡ desconectada -->
                                <DataTrigger Binding="{Binding ElementName=RootControl, Path=Conectada}" Value="False">
                                    <Setter Property="Text" Value="Desconectado"/>
                                    <Setter Property="BackgroundColor" Value="#9CA3AF"/>
                                    <Setter Property="IsEnabled" Value="False"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </form:CustomButton.Style>
                </form:CustomButton>
                
                <!-- Indicador de estabilidad superpuesto -->
                <Ellipse Width="10"
                        Height="10"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,8,0"
                        IsHitTestVisible="False">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <!-- Por defecto: amarillo (estabilizando) -->
                            <Setter Property="Fill" Value="#FCD34D"/>
                            <Style.Triggers>
                                <!-- Verde cuando estÃ¡ estable -->
                                <DataTrigger Binding="{Binding ElementName=RootControl, Path=EsEstable}" Value="True">
                                    <Setter Property="Fill" Value="#10B981"/>
                                </DataTrigger>
                                <!-- Rojo cuando estÃ¡ desconectado -->
                                <DataTrigger Binding="{Binding ElementName=RootControl, Path=Conectada}" Value="False">
                                    <Setter Property="Fill" Value="#EF4444"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
            </Grid>
        </Grid>
    </Border>
</UserControl>

