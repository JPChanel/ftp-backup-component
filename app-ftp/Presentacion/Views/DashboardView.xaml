<UserControl x:Class="app_ftp.Presentacion.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:app_ftp.Config.Converters"
             xmlns:form="clr-namespace:app_ftp.Presentacion.Shared.Controls.Form"
             mc:Ignorable="d">
    <UserControl.Resources>
        <converters:StringNullOrEmptyToVisibilityConverter x:Key="StringNullOrEmptyToVisibilityConverter" />
        <converters:StatusToBrushConverter x:Key="StatusToBrushConverter" />
        <Style x:Key="ConsoleBadgeStyle" TargetType="Border">
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="CornerRadius" Value="9" />
            <Setter Property="Background" Value="#172554" />
            <Setter Property="BorderBrush" Value="#1D4ED8" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="ConsoleStatusBadgeStyle" TargetType="Border">
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="CornerRadius" Value="9" />
            <Setter Property="Background" Value="#0F3D2E" />
            <Setter Property="BorderBrush" Value="#14532D" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="ConsoleStatusTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#86EFAC" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <UniformGrid Columns="3" Margin="0,0,0,16">
            <materialDesign:Card Margin="0,0,16,16" Padding="22" UniformCornerRadius="18" Background="White" materialDesign:ElevationAssist.Elevation="Dp2">
                <StackPanel>
                    <TextBlock Text="BACKUPS EXITOSOS" Foreground="#64748B" />
                    <TextBlock Margin="0,10,0,0" Text="{Binding SuccessCount}" FontSize="30" FontWeight="Bold" />
                </StackPanel>
            </materialDesign:Card>
            <materialDesign:Card Margin="0,0,16,16" Padding="22" UniformCornerRadius="18" Background="White" materialDesign:ElevationAssist.Elevation="Dp2">
                <StackPanel>
                    <TextBlock Text="ESPACIO TRANSFERIDO" Foreground="#64748B" />
                    <TextBlock Margin="0,10,0,0" Text="{Binding TotalTransferredText}" FontSize="30" FontWeight="Bold" />
                </StackPanel>
            </materialDesign:Card>
            <materialDesign:Card Margin="0,0,0,16" Padding="22" UniformCornerRadius="18" Background="White" materialDesign:ElevationAssist.Elevation="Dp2">
                <StackPanel>
                    <TextBlock Text="TAREAS FALLIDAS" Foreground="#64748B" />
                    <TextBlock Margin="0,10,0,0" Text="{Binding FailedCount}" FontSize="30" FontWeight="Bold" Foreground="#DC2626" />
                </StackPanel>
            </materialDesign:Card>
        </UniformGrid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <materialDesign:Card Grid.Column="0" Margin="0,0,16,0" Padding="24" UniformCornerRadius="18" Background="White" materialDesign:ElevationAssist.Elevation="Dp2">
                <StackPanel>
                    <TextBlock Text="Ejecutar Nuevo Backup" FontSize="24" FontWeight="SemiBold" />
                    <TextBlock Margin="0,6,0,20" Text="Orquesta transferencias entre carpeta local, FTP y SFTP con trazabilidad." Foreground="#64748B" />

                    <ComboBox SelectedItem="{Binding SelectedSourceConnection}" ItemsSource="{Binding Connections}" DisplayMemberPath="DisplayName"
                              Style="{StaticResource MaterialDesignFilledComboBox}" materialDesign:HintAssist.Hint="Conexion origen" Margin="0,0,0,14" />
                    <TextBlock Margin="0,-6,0,10"
                               Foreground="#475569"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Text="{Binding SourceRootDisplay}" />
                    <form:FormField Label="Ruta origen opcional"
                                    Value="{Binding SourcePath, UpdateSourceTrigger=PropertyChanged}"
                                    Margin="0,0,0,14" />
                    <TextBlock Margin="0,-6,0,8"
                               Foreground="#334155"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Text="{Binding SourceRoutePreview, StringFormat=Ruta normalizada: {0}}" />
                    <TextBlock Margin="0,-6,0,12"
                               Foreground="#64748B"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Text="Ejemplos: vacio o / = toda la raiz configurada, /REGISTROS_VJ y REGISTROS_VJ se interpretan igual, REGISTROS_VJ/2026 = carpeta interna." />
                    <ComboBox SelectedItem="{Binding SelectedDestinationConnection}" ItemsSource="{Binding AvailableDestinationConnections}" DisplayMemberPath="DisplayName"
                              Style="{StaticResource MaterialDesignFilledComboBox}" materialDesign:HintAssist.Hint="Conexion destino" Margin="0,0,0,14" />
                    <TextBlock Margin="0,-6,0,10"
                               Foreground="#475569"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Text="{Binding DestinationRootDisplay}" />
                    <form:FormField Label="Ruta destino opcional"
                                    Value="{Binding DestinationPath, UpdateSourceTrigger=PropertyChanged}"
                                    Margin="0,0,0,14" />
                    <TextBlock Margin="0,-6,0,8"
                               Foreground="#334155"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Text="{Binding DestinationRoutePreview, StringFormat=Ruta normalizada: {0}}" />
                    <TextBlock Margin="0,-6,0,12"
                               Foreground="#64748B"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Text="Ejemplos: vacio o / = raiz del destino, /backups y backups se interpretan igual, backups/ftp_desa = subcarpeta de destino." />
                    <TextBlock Margin="0,0,0,10"
                               Foreground="#64748B"
                               FontSize="10"
                               TextWrapping="Wrap"
                               Text="Nota: Las rutas en ejecutar se interpretan como carpetas. Si el archivo ya existe en destino, solo se reemplaza cuando el origen es mas reciente. Si el destino tiene una version igual o mas vigente, no se copia." />
                    <CheckBox IsChecked="{Binding DeleteSourceAfterCopy}" Content="Eliminar archivo origen tras copia verificada" Margin="0,0,0,16" />
                    <WrapPanel>
                        <Button Width="260" Height="48" HorizontalAlignment="Left" Command="{Binding RunBackupCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Content="{Binding RunBackupButtonText}" />
                        <Button Margin="12,0,0,0"
                                Width="180"
                                Height="48"
                                HorizontalAlignment="Left"
                                Command="{Binding CancelBackupCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Content="Cancelar"
                                Visibility="{Binding IsRunningBackup, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </WrapPanel>
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Grid.Column="1" Padding="24" UniformCornerRadius="18" Background="White" materialDesign:ElevationAssist.Elevation="Dp2">
                <StackPanel>
                    <TextBlock Text="Filtros y notas" FontSize="22" FontWeight="SemiBold" />
                    <CheckBox Margin="0,18,0,12"
                              IsChecked="{Binding UseFilterTime, Mode=TwoWay}"
                              Content="Especificar hora exacta" />
                    <form:FormDatePicker Label="Desde"
                                         Value="{Binding FilterFromDate, Mode=TwoWay}"
                                         Margin="0,0,0,14"
                                         Visibility="{Binding UseFilterTime, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                    <form:FormDateTimePicker Label="Desde"
                                             Value="{Binding FilterFromDate, Mode=TwoWay}"
                                             Margin="0,0,0,14"
                                             Visibility="{Binding UseFilterTime, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <form:FormDatePicker Label="Hasta"
                                         Value="{Binding FilterToDate, Mode=TwoWay}"
                                         Margin="0,0,0,14"
                                         Visibility="{Binding UseFilterTime, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                    <form:FormDateTimePicker Label="Hasta"
                                             Value="{Binding FilterToDate, Mode=TwoWay}"
                                             Margin="0,0,0,14"
                                             Visibility="{Binding UseFilterTime, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <form:FormField Label="Notas"
                                    Value="{Binding BackupNotes, UpdateSourceTrigger=PropertyChanged}"
                                    Variant="TextArea"
                                    MinHeight="80"
                                    Margin="0,0,0,14" />
                    <TextBlock Text="Si no indicas fechas, el backup se ejecuta sin filtro. Sin hora exacta, 'Desde' inicia a las 00:00 y 'Hasta' termina a las 23:59 del dia elegido."
                               Foreground="#64748B"
                               TextWrapping="Wrap" />
                </StackPanel>
            </materialDesign:Card>
        </Grid>

        <Border Grid.RowSpan="2"
                Panel.ZIndex="20"
                Background="#B30B1020"
                Visibility="{Binding IsBackupConsoleOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Border Margin="32"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Center"
                        MaxWidth="860"
                        MaxHeight="680"
                        Background="#0F172A"
                        BorderBrush="#334155"
                        BorderThickness="1"
                        CornerRadius="24"
                        SnapsToDevicePixels="True">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="24,22,20,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="46"
                                        Height="46"
                                        Margin="0,0,14,0"
                                        Background="#172554"
                                        CornerRadius="14">
                                    <materialDesign:PackIcon Kind="ConsoleLine"
                                                             Width="24"
                                                             Height="24"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center"
                                                             Foreground="#93C5FD" />
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Consola de Backup"
                                               FontSize="22"
                                               FontWeight="SemiBold"
                                               Foreground="#F8FAFC" />
                                    <TextBlock Margin="0,4,0,0"
                                               Text="{Binding BackupConsoleStatus}"
                                               FontSize="12"
                                               Foreground="#93A4BF"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Width="36"
                                    Height="36"
                                    Command="{Binding CloseBackupConsoleCommand}"
                                    Style="{StaticResource MaterialDesignToolButton}"
                                    IsEnabled="{Binding CanCloseBackupConsole}">
                                <materialDesign:PackIcon Kind="Close" Foreground="#CBD5E1" />
                            </Button>
                        </Grid>

                        <ProgressBar Grid.Row="1"
                                     Margin="24,0,24,12"
                                     Height="4"
                                     IsIndeterminate="True"
                                     Foreground="#38BDF8"
                                     Background="#1E293B"
                                     BorderThickness="0"
                                     Visibility="{Binding IsRunningBackup, Converter={StaticResource BooleanToVisibilityConverter}}" />

                        <WrapPanel Grid.Row="2" Margin="24,0,24,16">
                            <Border Style="{StaticResource ConsoleBadgeStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Pulse"
                                                             Width="16"
                                                             Height="16"
                                                             Margin="0,0,6,0"
                                                             Foreground="#7DD3FC" />
                                    <TextBlock Text="Seguimiento en tiempo real"
                                               FontSize="12"
                                               Foreground="#E0F2FE" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ConsoleBadgeStyle}" Background="#1E293B" BorderBrush="#334155">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="FormatListBulleted"
                                                             Width="16"
                                                             Height="16"
                                                             Margin="0,0,6,0"
                                                             Foreground="#CBD5E1" />
                                    <TextBlock Text="{Binding BackupConsoleEntries.Count, StringFormat={}{0} eventos}"
                                               FontSize="12"
                                               Foreground="#E2E8F0" />
                                </StackPanel>
                            </Border>
                        </WrapPanel>

                        <Border Grid.Row="2"
                                Margin="24,36,24,0"
                                Padding="12,10"
                                Background="#111827"
                                BorderBrush="#1E293B"
                                BorderThickness="1"
                                CornerRadius="12"
                                Visibility="{Binding BackupNotes, Converter={StaticResource StringNullOrEmptyToVisibilityConverter}, FallbackValue=Collapsed}">
                            <StackPanel>
                                <TextBlock Text="Notas del backup"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#CBD5E1" />
                                <TextBlock Margin="0,6,0,0"
                                           Text="{Binding BackupNotes}"
                                           Foreground="#94A3B8"
                                           FontSize="12"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="3"
                                Margin="24,48,24,0"
                                Background="#020617"
                                BorderBrush="#1E293B"
                                BorderThickness="1"
                                CornerRadius="16">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0"
                                        Padding="16,12"
                                        Background="#111827"
                                        BorderBrush="#1E293B"
                                        BorderThickness="0,0,0,1"
                                        CornerRadius="16,16,0,0">
                                    <DockPanel>
                                        <TextBlock Text="Actividad"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="#E2E8F0" />
                                        <TextBlock DockPanel.Dock="Right"
                                                   Text="Ultimos eventos del proceso"
                                                   FontSize="11"
                                                   Foreground="#64748B" />
                                    </DockPanel>
                                </Border>

                                <ListBox x:Name="BackupConsoleList"
                                         Grid.Row="1"
                                         ItemsSource="{Binding BackupConsoleEntries}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.CanContentScroll="True"
                                         VirtualizingPanel.IsVirtualizing="True"
                                         VirtualizingPanel.VirtualizationMode="Recycling"
                                         FontFamily="Consolas">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="0" />
                                            <Setter Property="Margin" Value="0" />
                                            <Setter Property="Background" Value="Transparent" />
                                            <Setter Property="Focusable" Value="False" />
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="14,10"
                                                    BorderBrush="#0F172A"
                                                    BorderThickness="0,0,0,1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="88" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding TimestampText, Mode=OneWay}"
                                                               Foreground="#38BDF8"
                                                               FontSize="12"
                                                               VerticalAlignment="Top" />
                                                    <TextBlock Grid.Column="1"
                                                               Margin="10,0,12,0"
                                                               Text="{Binding FileName, Mode=OneWay}"
                                                               Foreground="#E2E8F0"
                                                               FontSize="12"
                                                               TextWrapping="Wrap"
                                                               VerticalAlignment="Center" />
                                                    <Border Grid.Column="2"
                                                            VerticalAlignment="Center"
                                                            Style="{StaticResource ConsoleStatusBadgeStyle}"
                                                            Background="{Binding Status, Converter={StaticResource StatusToBrushConverter}, ConverterParameter=Background}"
                                                            BorderBrush="{Binding Status, Converter={StaticResource StatusToBrushConverter}, ConverterParameter=Border}">
                                                        <TextBlock Text="{Binding Status, Mode=OneWay}"
                                                                   Style="{StaticResource ConsoleStatusTextStyle}"
                                                                   Foreground="{Binding Status, Converter={StaticResource StatusToBrushConverter}, ConverterParameter=Foreground}"
                                                                   HorizontalAlignment="Center" />
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                        <Border Grid.Row="4" Margin="0,14,0,0" Background="#111827" CornerRadius="0,0,24,24">
                            <Grid Margin="24,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock VerticalAlignment="Center"
                                           Foreground="#64748B"
                                           FontSize="11"
                                           Text="Puedes cerrar la consola cuando el proceso termine." />
                                <WrapPanel Grid.Column="1" HorizontalAlignment="Right">
                                    <Button Margin="0,0,10,0"
                                            MinWidth="160"
                                            Height="40"
                                            Command="{Binding CancelBackupCommand}"
                                            Style="{StaticResource MaterialDesignOutlinedButton}"
                                            Content="Cancelar backup"
                                            Visibility="{Binding IsRunningBackup, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    <Button MinWidth="120"
                                            Height="40"
                                            Command="{Binding CloseBackupConsoleCommand}"
                                            Style="{StaticResource MaterialDesignRaisedButton}"
                                            Content="Cerrar"
                                            IsEnabled="{Binding CanCloseBackupConsole}" />
                                </WrapPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>

