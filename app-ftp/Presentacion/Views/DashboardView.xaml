<UserControl x:Class="app_ftp.Presentacion.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:app_ftp.Config.Converters"
             xmlns:form="clr-namespace:app_ftp.Presentacion.Shared.Controls.Form"
             mc:Ignorable="d">
    <UserControl.Resources>
        <converters:StringNullOrEmptyToVisibilityConverter x:Key="StringNullOrEmptyToVisibilityConverter" />
        <converters:StatusToBrushConverter x:Key="StatusToBrushConverter" />

        <Style x:Key="MetricCardStyle" TargetType="materialDesign:Card">
            <Setter Property="Margin" Value="0,0,18,18" />
            <Setter Property="Padding" Value="22" />
            <Setter Property="Background" Value="White" />
            <Setter Property="UniformCornerRadius" Value="28" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp2" />
        </Style>

        <Style x:Key="SectionCardStyle" TargetType="materialDesign:Card">
            <Setter Property="Padding" Value="28" />
            <Setter Property="Background" Value="White" />
            <Setter Property="UniformCornerRadius" Value="34" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp2" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#94A3B8" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="ConsoleBadgeStyle" TargetType="Border">
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Background" Value="#172554" />
            <Setter Property="BorderBrush" Value="#1D4ED8" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="ConsoleStatusBadgeStyle" TargetType="Border">
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Background" Value="#0F3D2E" />
            <Setter Property="BorderBrush" Value="#14532D" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="ConsoleStatusTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#86EFAC" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="DashboardContentBlurStyle" TargetType="FrameworkElement">
            <Setter Property="Effect" Value="{x:Null}" />
            <Setter Property="Opacity" Value="1" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsBackupConsoleOpen}" Value="True">
                    <Setter Property="Opacity" Value="0.82" />
                    <Setter Property="Effect">
                        <Setter.Value>
                            <BlurEffect Radius="11" />
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="#020617" />
        </Style>

        <Style TargetType="Thumb">
            <Setter Property="Background" Value="#334155" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="thumb"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="thumb" Property="Background" Value="#60A5FA" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid MinHeight="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=ScrollViewer}}" Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,24"
                    Style="{StaticResource DashboardContentBlurStyle}">
            <TextBlock Text="Centro de Operaciones"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#0F172A" />
            <TextBlock Margin="0,6,0,0"
                       Text="Orquesta transferencias entre carpetas locales, FTP y SFTP."
                       FontSize="15"
                       Foreground="#64748B" />
        </StackPanel>

        <UniformGrid Grid.Row="1"
                     Style="{StaticResource DashboardContentBlurStyle}"
                     Columns="3"
                     Margin="0,0,0,24">
            <materialDesign:Card Style="{StaticResource MetricCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Width="54"
                            Height="54"
                            Margin="0,0,16,0"
                            Background="#E9FBF3"
                            CornerRadius="18">
                        <materialDesign:PackIcon Kind="CheckCircle"
                                                 Width="22"
                                                 Height="22"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center"
                                                 Foreground="#10B981" />
                    </Border>
                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center">
                        <TextBlock Text="BACKUPS EXITOSOS"
                                   Style="{StaticResource FieldLabelStyle}" />
                        <TextBlock Margin="0,4,0,0"
                                   Text="{Binding SuccessCount}"
                                   FontSize="25"
                                   FontWeight="Bold"
                                   Foreground="#1E293B" />
                    </StackPanel>
                </Grid>
            </materialDesign:Card>

            <materialDesign:Card Style="{StaticResource MetricCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Width="54"
                            Height="54"
                            Margin="0,0,16,0"
                            Background="#EEF2FF"
                            CornerRadius="18">
                        <materialDesign:PackIcon Kind="Database"
                                                 Width="22"
                                                 Height="22"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center"
                                                 Foreground="{StaticResource PrimaryHueMidBrush}" />
                    </Border>
                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center">
                        <TextBlock Text="ESPACIO TRANSFERIDO"
                                   Style="{StaticResource FieldLabelStyle}" />
                        <TextBlock Margin="0,4,0,0"
                                   Text="{Binding TotalTransferredText}"
                                   FontSize="25"
                                   FontWeight="Bold"
                                   Foreground="#1E293B" />
                    </StackPanel>
                </Grid>
            </materialDesign:Card>

            <materialDesign:Card Margin="0,0,0,18"
                                 Padding="22"
                                 Background="White"
                                 UniformCornerRadius="28"
                                 BorderThickness="0"
                                 materialDesign:ElevationAssist.Elevation="Dp2">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Width="54"
                            Height="54"
                            Margin="0,0,16,0"
                            Background="#FFF1F2"
                            CornerRadius="18">
                        <materialDesign:PackIcon Kind="Alert"
                                                 Width="22"
                                                 Height="22"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center"
                                                 Foreground="#F43F5E" />
                    </Border>
                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center">
                        <TextBlock Text="TAREAS FALLIDAS"
                                   Style="{StaticResource FieldLabelStyle}" />
                        <TextBlock Margin="0,4,0,0"
                                   Text="{Binding FailedCount}"
                                   FontSize="25"
                                   FontWeight="Bold"
                                   Foreground="#1E293B" />
                    </StackPanel>
                </Grid>
            </materialDesign:Card>
        </UniformGrid>

        <Grid Grid.Row="2"
              Style="{StaticResource DashboardContentBlurStyle}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="340" />
            </Grid.ColumnDefinitions>

            <materialDesign:Card Grid.Column="0"
                                 Margin="0,0,22,0"
                                 Style="{StaticResource SectionCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Margin="0,0,0,24"
                                Orientation="Horizontal">
                        <Border Width="38"
                                Height="38"
                                Margin="0,0,12,0"
                                Background="#EEF2FF"
                                CornerRadius="14">
                            <materialDesign:PackIcon Kind="RocketLaunch"
                                                     Width="18"
                                                     Height="18"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"
                                                     Foreground="{StaticResource PrimaryHueMidBrush}" />
                        </Border>
                        <StackPanel>
                            <TextBlock Text="Ejecutar Nuevo Backup"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="#1E293B" />
                            <TextBlock Margin="0,4,0,0"
                                       Text="Configura origen, destino y reglas antes de iniciar."
                                       Foreground="#64748B" />
                        </StackPanel>
                    </StackPanel>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Margin="0,0,0,8"
                                   Text="CONEXION ORIGEN"
                                   Style="{StaticResource FieldLabelStyle}" />
                        <TextBlock Grid.Row="0"
                                   Grid.Column="2"
                                   Margin="0,0,0,8"
                                   Text="RUTA ORIGEN OPCIONAL"
                                   Style="{StaticResource FieldLabelStyle}" />

                        <ComboBox Grid.Row="1"
                                  Grid.Column="0"
                                  Height="54"
                                  ItemsSource="{Binding Connections}"
                                  SelectedItem="{Binding SelectedSourceConnection}"
                                  DisplayMemberPath="DisplayName"
                                  Style="{StaticResource AppFilledComboBox}" />
                        <TextBox Grid.Row="1"
                                 Grid.Column="2"
                                 Height="54"
                                 Text="{Binding SourcePath, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource AppFilledTextBox}"
                                 materialDesign:HintAssist.Hint="Ejemplo: /registros/2024" />

                        <TextBlock Grid.Row="2"
                                   Grid.Column="0"
                                   Margin="0,8,0,0"
                                   Text="{Binding SourceRootDisplay}"
                                   FontSize="11"
                                   Foreground="#94A3B8"
                                   TextWrapping="Wrap" />
                        <TextBlock Grid.Row="2"
                                   Grid.Column="2"
                                   Margin="0,8,0,0"
                                   Text="{Binding SourceRoutePreview, StringFormat=Ruta normalizada: {0}}"
                                   FontSize="11"
                                   Foreground="#94A3B8"
                                   TextWrapping="Wrap" />
                    </Grid>

                    <Border Grid.Row="2"
                            Margin="0,14"
                            Height="1"
                            Background="#EEF2FF" />

                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Margin="0,0,0,8"
                                   Text="CONEXION DESTINO"
                                   Style="{StaticResource FieldLabelStyle}" />
                        <TextBlock Grid.Row="0"
                                   Grid.Column="2"
                                   Margin="0,0,0,8"
                                   Text="RUTA DESTINO OPCIONAL"
                                   Style="{StaticResource FieldLabelStyle}" />

                        <ComboBox Grid.Row="1"
                                  Grid.Column="0"
                                  Height="54"
                                  ItemsSource="{Binding AvailableDestinationConnections}"
                                  SelectedItem="{Binding SelectedDestinationConnection}"
                                  DisplayMemberPath="DisplayName"
                                  Style="{StaticResource AppFilledComboBox}" />
                        <TextBox Grid.Row="1"
                                 Grid.Column="2"
                                 Height="54"
                                 Text="{Binding DestinationPath, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource AppFilledTextBox}"
                                 materialDesign:HintAssist.Hint="Ejemplo: /backups/ftp_desa" />

                        <TextBlock Grid.Row="2"
                                   Grid.Column="0"
                                   Margin="0,8,0,0"
                                   Text="{Binding DestinationRootDisplay}"
                                   FontSize="11"
                                   Foreground="#94A3B8"
                                   TextWrapping="Wrap" />
                        <TextBlock Grid.Row="2"
                                   Grid.Column="2"
                                   Margin="0,8,0,0"
                                   Text="{Binding DestinationRoutePreview, StringFormat=Ruta normalizada: {0}}"
                                   FontSize="11"
                                   Foreground="#94A3B8"
                                   TextWrapping="Wrap" />
                    </Grid>

                    <Border Grid.Row="4"
                            Margin="0,24,0,18"
                            Padding="18,14"
                            Background="#FFFBEF"
                            BorderBrush="#FDE7AE"
                            BorderThickness="1"
                            CornerRadius="18">
                        <CheckBox IsChecked="{Binding DeleteSourceAfterCopy}"
                                  Content="Eliminar archivo origen tras copia verificada"
                                  VerticalAlignment="Center" />
                    </Border>

                    <StackPanel Grid.Row="5">
                        <TextBlock Margin="0,0,0,16"
                                   Text="Las rutas se interpretan como carpetas. Si el archivo en destino ya esta actualizado, no se vuelve a copiar."
                                   FontSize="11"
                                   Foreground="#94A3B8"
                                   TextWrapping="Wrap" />
                        <Button Height="56"
                                HorizontalAlignment="Stretch"
                                Command="{Binding RunBackupCommand}"
                                Style="{StaticResource AppRaisedButton}"
                                Content="{Binding RunBackupButtonText}" />
                        <Button Margin="0,12,0,0"
                                Height="44"
                                HorizontalAlignment="Stretch"
                                Command="{Binding CancelBackupCommand}"
                                Style="{StaticResource AppOutlinedButton}"
                                Content="Cancelar"
                                Visibility="{Binding IsRunningBackup, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </StackPanel>
                </Grid>
            </materialDesign:Card>

            <materialDesign:Card Grid.Column="1"
                                 Style="{StaticResource SectionCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Margin="0,0,0,22"
                                Orientation="Horizontal">
                        <Border Width="36"
                                Height="36"
                                Margin="0,0,12,0"
                                Background="#EEF2FF"
                                CornerRadius="14">
                            <materialDesign:PackIcon Kind="FilterVariant"
                                                     Width="18"
                                                     Height="18"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"
                                                     Foreground="{StaticResource PrimaryHueMidBrush}" />
                        </Border>
                        <TextBlock Text="Filtros y Notas"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   Foreground="#1E293B" />
                    </StackPanel>

                    <CheckBox Grid.Row="1"
                              Margin="0,0,0,18"
                              IsChecked="{Binding UseFilterTime, Mode=TwoWay}"
                              Content="Especificar hora exacta" />

                    <TextBlock Grid.Row="2"
                               Margin="0,0,0,8"
                               Text="DESDE"
                               Style="{StaticResource FieldLabelStyle}" />
                    <form:FormDatePicker Grid.Row="3"
                                         Value="{Binding FilterFromDate, Mode=TwoWay}"
                                         IsInputValid="{Binding IsDateFromInputValid, Mode=TwoWay}"
                                         ValidationMessage="{Binding DateFromValidationMessage, Mode=TwoWay}"
                                         Margin="0,0,0,14"
                                         Visibility="{Binding UseFilterTime, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                    <form:FormDateTimePicker Grid.Row="3"
                                             Value="{Binding FilterFromDate, Mode=TwoWay}"
                                             IsInputValid="{Binding IsDateTimeFromInputValid, Mode=TwoWay}"
                                             ValidationMessage="{Binding DateTimeFromValidationMessage, Mode=TwoWay}"
                                             Margin="0,0,0,14"
                                             Visibility="{Binding UseFilterTime, Converter={StaticResource BooleanToVisibilityConverter}}" />

                    <StackPanel Grid.Row="4">
                        <TextBlock Margin="0,0,0,8"
                                   Text="HASTA"
                                   Style="{StaticResource FieldLabelStyle}" />
                        <form:FormDatePicker Value="{Binding FilterToDate, Mode=TwoWay}"
                                             IsInputValid="{Binding IsDateToInputValid, Mode=TwoWay}"
                                             ValidationMessage="{Binding DateToValidationMessage, Mode=TwoWay}"
                                             Margin="0,0,0,14"
                                             Visibility="{Binding UseFilterTime, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                        <form:FormDateTimePicker Value="{Binding FilterToDate, Mode=TwoWay}"
                                                 IsInputValid="{Binding IsDateTimeToInputValid, Mode=TwoWay}"
                                                 ValidationMessage="{Binding DateTimeToValidationMessage, Mode=TwoWay}"
                                                 Margin="0,0,0,14"
                                                 Visibility="{Binding UseFilterTime, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </StackPanel>

                    <StackPanel Grid.Row="5">
                        <TextBlock Margin="0,0,0,8"
                                   Text="NOTAS INTERNAS"
                                   Style="{StaticResource FieldLabelStyle}" />
                        <TextBox Text="{Binding BackupNotes, UpdateSourceTrigger=PropertyChanged}"
                                 MinHeight="108"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Style="{StaticResource AppFilledTextBox}"
                                 materialDesign:HintAssist.Hint="Anade un comentario sobre este job..." />
                        <TextBlock Margin="0,14,0,0"
                                   Text="{Binding DateFilterValidationMessage}"
                                   Foreground="#DC2626"
                                   TextWrapping="Wrap"
                                   Visibility="{Binding HasDateFilterValidationMessage, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </StackPanel>

                    <Border Grid.Row="6"
                            Margin="0,22,0,0"
                            Padding="16"
                            Background="#EEF4FF"
                            BorderBrush="#D8E4FF"
                            BorderThickness="1"
                            CornerRadius="20">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Information"
                                                     Width="18"
                                                     Height="18"
                                                     Margin="0,1,10,0"
                                                     Foreground="{StaticResource PrimaryHueMidBrush}" />
                            <TextBlock Width="240"
                                       Text="Si no indicas fechas, el backup se ejecuta sin filtro. Versiones iguales o mas vigentes en destino no se copiaran."
                                       FontSize="11"
                                       Foreground="#4F46E5"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
            </materialDesign:Card>
        </Grid>

        <Border Grid.RowSpan="3"
                Panel.ZIndex="60"
                Visibility="{Binding IsBackupConsoleOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid Margin="18">
                <Border Margin="32"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        MaxWidth="900"
                        MaxHeight="700"
                        Background="#0F172A"
                        BorderBrush="#334155"
                        BorderThickness="1"
                        CornerRadius="28"
                        SnapsToDevicePixels="True">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0"
                              Margin="24,22,20,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="46"
                                        Height="46"
                                        Margin="0,0,14,0"
                                        Background="#172554"
                                        CornerRadius="16">
                                    <materialDesign:PackIcon Kind="ConsoleLine"
                                                             Width="24"
                                                             Height="24"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center"
                                                             Foreground="#93C5FD" />
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Consola de Backup"
                                               FontSize="22"
                                               FontWeight="SemiBold"
                                               Foreground="#F8FAFC" />
                                    <TextBlock Margin="0,4,0,0"
                                               Text="{Binding BackupConsoleStatus}"
                                               FontSize="12"
                                               Foreground="#93A4BF"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Command="{Binding CloseBackupConsoleCommand}"
                                    Style="{StaticResource AppToolButton}"
                                    IsEnabled="{Binding CanCloseBackupConsole}">
                                <materialDesign:PackIcon Kind="Close"
                                                         Foreground="#CBD5E1" />
                            </Button>
                        </Grid>

                        <ProgressBar Grid.Row="1"
                                     Margin="24,0,24,12"
                                     Height="4"
                                     IsIndeterminate="True"
                                     Foreground="#38BDF8"
                                     Background="#1E293B"
                                     BorderThickness="0"
                                     Visibility="{Binding IsRunningBackup, Converter={StaticResource BooleanToVisibilityConverter}}" />

                        <WrapPanel Grid.Row="2"
                                   Margin="24,0,24,16">
                            <Border Style="{StaticResource ConsoleBadgeStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Pulse"
                                                             Width="16"
                                                             Height="16"
                                                             Margin="0,0,6,0"
                                                             Foreground="#7DD3FC" />
                                    <TextBlock Text="Seguimiento en tiempo real"
                                               FontSize="12"
                                               Foreground="#E0F2FE" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ConsoleBadgeStyle}"
                                    Background="#1E293B"
                                    BorderBrush="#334155">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="FormatListBulleted"
                                                             Width="16"
                                                             Height="16"
                                                             Margin="0,0,6,0"
                                                             Foreground="#CBD5E1" />
                                    <TextBlock Text="{Binding BackupConsoleEntries.Count, StringFormat={}{0} eventos}"
                                               FontSize="12"
                                               Foreground="#E2E8F0" />
                                </StackPanel>
                            </Border>
                        </WrapPanel>

                        <Border Grid.Row="2"
                                Margin="24,36,24,0"
                                Padding="12,10"
                                Background="#111827"
                                BorderBrush="#1E293B"
                                BorderThickness="1"
                                CornerRadius="14"
                                Visibility="{Binding BackupNotes, Converter={StaticResource StringNullOrEmptyToVisibilityConverter}, FallbackValue=Collapsed}">
                            <StackPanel>
                                <TextBlock Text="Notas del backup"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#CBD5E1" />
                                <TextBlock Margin="0,6,0,0"
                                           Text="{Binding BackupNotes}"
                                           Foreground="#94A3B8"
                                           FontSize="12"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="3"
                                Margin="24,48,24,0"
                                Background="#020617"
                                BorderBrush="#1E293B"
                                BorderThickness="1"
                                CornerRadius="18">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0"
                                        Padding="16,12"
                                        Background="#111827"
                                        BorderBrush="#1E293B"
                                        BorderThickness="0,0,0,1"
                                        CornerRadius="18,18,0,0">
                                    <DockPanel>
                                        <TextBlock Text="Actividad"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="#E2E8F0" />
                                        <TextBlock DockPanel.Dock="Right"
                                                   Text="Ultimos eventos del proceso"
                                                   FontSize="11"
                                                   Foreground="#64748B" />
                                    </DockPanel>
                                </Border>

                                <ListBox x:Name="BackupConsoleList"
                                         Grid.Row="1"
                                         ItemsSource="{Binding BackupConsoleEntries}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                         ScrollViewer.CanContentScroll="True"
                                         VirtualizingPanel.IsVirtualizing="True"
                                         VirtualizingPanel.VirtualizationMode="Recycling"
                                         FontFamily="Consolas">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="0" />
                                            <Setter Property="Margin" Value="0" />
                                            <Setter Property="Background" Value="Transparent" />
                                            <Setter Property="Focusable" Value="False" />
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="14,10"
                                                    BorderBrush="#0F172A"
                                                    BorderThickness="0,0,0,1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="88" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding TimestampText, Mode=OneWay}"
                                                               Foreground="#38BDF8"
                                                               FontSize="12"
                                                               VerticalAlignment="Top" />
                                                    <TextBlock Grid.Column="1"
                                                               Margin="10,0,12,0"
                                                               Text="{Binding FileName, Mode=OneWay}"
                                                               ToolTip="{Binding FileName, Mode=OneWay}"
                                                               Foreground="#E2E8F0"
                                                               FontSize="12"
                                                               TextWrapping="NoWrap"
                                                               TextTrimming="CharacterEllipsis"
                                                               VerticalAlignment="Center" />
                                                    <Border Grid.Column="2"
                                                            VerticalAlignment="Center"
                                                            Style="{StaticResource ConsoleStatusBadgeStyle}"
                                                            Background="{Binding Status, Converter={StaticResource StatusToBrushConverter}, ConverterParameter=Background}"
                                                            BorderBrush="{Binding Status, Converter={StaticResource StatusToBrushConverter}, ConverterParameter=Border}">
                                                        <TextBlock Text="{Binding Status, Mode=OneWay}"
                                                                   Style="{StaticResource ConsoleStatusTextStyle}"
                                                                   Foreground="{Binding Status, Converter={StaticResource StatusToBrushConverter}, ConverterParameter=Foreground}"
                                                                   HorizontalAlignment="Center" />
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                        <Border Grid.Row="4"
                                Margin="0,14,0,0"
                                Background="#111827"
                                CornerRadius="0,0,28,28">
                            <Grid Margin="24,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock VerticalAlignment="Center"
                                           Foreground="#64748B"
                                           FontSize="11"
                                           Text="Puedes cerrar la consola cuando el proceso termine." />
                                <WrapPanel Grid.Column="1"
                                           HorizontalAlignment="Right">
                                    <Button Margin="0,0,10,0"
                                            MinWidth="160"
                                            Height="40"
                                            Command="{Binding CancelBackupCommand}"
                                            Style="{StaticResource AppOutlinedButton}"
                                            Content="Cancelar backup"
                                            Visibility="{Binding IsRunningBackup, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    <Button MinWidth="120"
                                            Height="40"
                                            Command="{Binding CloseBackupConsoleCommand}"
                                            Style="{StaticResource AppRaisedButton}"
                                            Content="Cerrar"
                                            IsEnabled="{Binding CanCloseBackupConsole}" />
                                </WrapPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
