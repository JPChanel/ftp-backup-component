<UserControl x:Class="app_ftp.Presentacion.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:form="clr-namespace:app_ftp.Presentacion.Shared.Controls.Form"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <UniformGrid Columns="3" Margin="0,0,0,16">
            <materialDesign:Card Margin="0,0,16,16" Padding="22" UniformCornerRadius="18" Background="White" materialDesign:ElevationAssist.Elevation="Dp2">
                <StackPanel>
                    <TextBlock Text="BACKUPS EXITOSOS" Foreground="#64748B" />
                    <TextBlock Margin="0,10,0,0" Text="{Binding SuccessCount}" FontSize="30" FontWeight="Bold" />
                </StackPanel>
            </materialDesign:Card>
            <materialDesign:Card Margin="0,0,16,16" Padding="22" UniformCornerRadius="18" Background="White" materialDesign:ElevationAssist.Elevation="Dp2">
                <StackPanel>
                    <TextBlock Text="ESPACIO TRANSFERIDO" Foreground="#64748B" />
                    <TextBlock Margin="0,10,0,0" Text="{Binding TotalTransferredText}" FontSize="30" FontWeight="Bold" />
                </StackPanel>
            </materialDesign:Card>
            <materialDesign:Card Margin="0,0,0,16" Padding="22" UniformCornerRadius="18" Background="White" materialDesign:ElevationAssist.Elevation="Dp2">
                <StackPanel>
                    <TextBlock Text="TAREAS FALLIDAS" Foreground="#64748B" />
                    <TextBlock Margin="0,10,0,0" Text="{Binding FailedCount}" FontSize="30" FontWeight="Bold" Foreground="#DC2626" />
                </StackPanel>
            </materialDesign:Card>
        </UniformGrid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <materialDesign:Card Grid.Column="0" Margin="0,0,16,0" Padding="24" UniformCornerRadius="18" Background="White" materialDesign:ElevationAssist.Elevation="Dp2">
                <StackPanel>
                    <TextBlock Text="Ejecutar Nuevo Backup" FontSize="24" FontWeight="SemiBold" />
                    <TextBlock Margin="0,6,0,20" Text="Orquesta transferencias entre carpeta local, FTP y SFTP con trazabilidad." Foreground="#64748B" />

                    <ComboBox SelectedItem="{Binding SelectedSourceConnection}" ItemsSource="{Binding Connections}" DisplayMemberPath="DisplayName"
                              Style="{StaticResource MaterialDesignFilledComboBox}" materialDesign:HintAssist.Hint="Conexion origen" Margin="0,0,0,14" />
                    <form:FormField Label="Ruta origen opcional"
                                    Value="{Binding SourcePath, UpdateSourceTrigger=PropertyChanged}"
                                    Margin="0,0,0,14" />
                    <TextBlock Margin="0,-6,0,12"
                               Foreground="#64748B"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Text="Ejemplos: vacio = toda la raiz configurada, REGISTROS_VJ = subcarpeta, REGISTROS_VJ/2026 = carpeta interna." />
                    <ComboBox SelectedItem="{Binding SelectedDestinationConnection}" ItemsSource="{Binding AvailableDestinationConnections}" DisplayMemberPath="DisplayName"
                              Style="{StaticResource MaterialDesignFilledComboBox}" materialDesign:HintAssist.Hint="Conexion destino" Margin="0,0,0,14" />
                    <form:FormField Label="Ruta destino opcional"
                                    Value="{Binding DestinationPath, UpdateSourceTrigger=PropertyChanged}"
                                    Margin="0,0,0,14" />
                    <TextBlock Margin="0,-6,0,12"
                               Foreground="#64748B"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Text="Ejemplos: vacio = raiz del destino, backups = crea o usa esa carpeta, backups/ftp_desa = subcarpeta de destino." />
                    <TextBlock Margin="0,0,0,10"
                               Foreground="#64748B"
                               FontSize="10"
                               TextWrapping="Wrap"
                               Text="Nota: Las rutas en ejecutar se interpretan como carpetas. Si el archivo ya existe en destino, solo se reemplaza cuando el origen es mas reciente. Si el destino tiene una version igual o mas vigente, no se copia."  />
                    <CheckBox IsChecked="{Binding DeleteSourceAfterCopy}" Content="Eliminar archivo origen tras copia verificada" Margin="0,0,0,16" />
                    <WrapPanel>
                        <Button Width="260" Height="48" HorizontalAlignment="Left" Command="{Binding RunBackupCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Content="{Binding RunBackupButtonText}" />
                        <Button Margin="12,0,0,0"
                                Width="180"
                                Height="48"
                                HorizontalAlignment="Left"
                                Command="{Binding CancelBackupCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Content="Cancelar"
                                Visibility="{Binding IsRunningBackup, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </WrapPanel>
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Grid.Column="1" Padding="24" UniformCornerRadius="18" Background="White" materialDesign:ElevationAssist.Elevation="Dp2">
                <StackPanel>
                    <TextBlock Text="Filtros y notas" FontSize="22" FontWeight="SemiBold" />
                    <form:FormDatePicker Label="Desde"
                                         Value="{Binding FilterFromDate, Mode=TwoWay}"
                                         Margin="0,18,0,14" />
                    <form:FormDatePicker Label="Hasta"
                                         Value="{Binding FilterToDate, Mode=TwoWay}"
                                         Margin="0,0,0,14" />
                    <form:FormField Label="Notas"
                                    Value="{Binding BackupNotes, UpdateSourceTrigger=PropertyChanged}"
                                    Variant="TextArea"
                                    MinHeight="80"
                                    Margin="0,0,0,14" />
                    <TextBlock Text="Si no indicas fechas, el backup se ejecuta sin filtro." Foreground="#64748B" TextWrapping="Wrap" />
                </StackPanel>
            </materialDesign:Card>
        </Grid>
        <Border Grid.RowSpan="2"
                Background="#990B1020"
                Visibility="{Binding IsBackupConsoleOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Border Width="920"
                        MaxWidth="920"
                        MaxHeight="640"
                        Margin="24"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="#0F172A"
                        BorderBrush="#334155"
                        BorderThickness="1"
                        CornerRadius="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="18,14,14,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Consola de Backup"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Foreground="#F8FAFC" />
                                <TextBlock Text="{Binding BackupConsoleStatus}"
                                           FontSize="12"
                                           Foreground="#93A4BF" />
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Width="32"
                                    Height="32"
                                    Command="{Binding CloseBackupConsoleCommand}"
                                    Style="{StaticResource MaterialDesignToolButton}"
                                    IsEnabled="{Binding CanCloseBackupConsole}">
                                <materialDesign:PackIcon Kind="Close" Foreground="#CBD5E1" />
                            </Button>
                        </Grid>

                        <ProgressBar Grid.Row="1"
                                     Margin="18,0,18,10"
                                     Height="2"
                                     IsIndeterminate="True"
                                     Foreground="#38BDF8"
                                     Background="#1E293B"
                                     Visibility="{Binding IsRunningBackup, Converter={StaticResource BooleanToVisibilityConverter}}" />

                        <Border Grid.Row="2"
                                Margin="18,0,18,0"
                                Background="#020617"
                                BorderBrush="#1E293B"
                                BorderThickness="1"
                                CornerRadius="8">
                            <ListBox x:Name="BackupConsoleList"
                                     ItemsSource="{Binding BackupConsoleEntries}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     FontFamily="Consolas">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="Margin" Value="0" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="Focusable" Value="False" />
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="10,5" BorderBrush="#0F172A" BorderThickness="0,0,0,1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="90" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="160" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding TimestampText, Mode=OneWay}"
                                                           Foreground="#38BDF8"
                                                           FontSize="12" />
                                                <TextBlock Grid.Column="1"
                                                           Margin="8,0,8,0"
                                                           Text="{Binding FileName, Mode=OneWay}"
                                                           Foreground="#E2E8F0"
                                                           FontSize="12"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding Status, Mode=OneWay}"
                                                           Foreground="#86EFAC"
                                                           FontSize="12"
                                                           HorizontalAlignment="Left" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>

                        <Border Grid.Row="3" Margin="0,12,0,0" Background="#111827" CornerRadius="0,0,12,12">
                            <WrapPanel Margin="18,12" HorizontalAlignment="Right">
                                <Button Margin="0,0,10,0"
                                        MinWidth="160"
                                        Height="40"
                                        Command="{Binding CancelBackupCommand}"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        Content="Cancelar backup"
                                        Visibility="{Binding IsRunningBackup, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <Button MinWidth="120"
                                        Height="40"
                                        Command="{Binding CloseBackupConsoleCommand}"
                                        Style="{StaticResource MaterialDesignRaisedButton}"
                                        Content="Cerrar"
                                        IsEnabled="{Binding CanCloseBackupConsole}" />
                            </WrapPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>

