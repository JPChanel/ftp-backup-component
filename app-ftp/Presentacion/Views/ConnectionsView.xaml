<UserControl x:Class="app_ftp.Presentacion.Views.ConnectionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <DockPanel Margin="0,0,0,20">
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="Gestion de Conexiones" FontSize="28" FontWeight="SemiBold" />
                        <TextBlock Margin="0,4,0,0" Text='"Una buena configuracion es el backend de una vida tranquila."' Foreground="#64748B" FontStyle="Italic" />
                    </StackPanel>
                    <Button DockPanel.Dock="Right"
                            Height="42"
                            HorizontalAlignment="Right"
                            MinWidth="180"
                            Padding="20,0"
                            Command="{Binding CreateConnectionCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Content="+ Nueva Conexion" />
                </DockPanel>

                <ItemsControl ItemsSource="{Binding Connections}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <materialDesign:Card Margin="0,0,16,16"
                                                 Padding="10"
                                                 UniformCornerRadius="18"
                                                 Background="White"
                                                 materialDesign:ElevationAssist.Elevation="Dp2">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Border Width="36" Height="36" Background="#EEF2FF" CornerRadius="12" HorizontalAlignment="Left">
                                    <materialDesign:PackIcon Kind="Server"
                                                                 Width="16"
                                                                 Height="16"
                                                                 HorizontalAlignment="Center"
                                                                 VerticalAlignment="Center"
                                                                 Foreground="{StaticResource PrimaryHueMidBrush}" />
                                    </Border>

                                    <StackPanel Grid.Row="1" Margin="0,18,0,0">
                                        <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap" />
                                        <TextBlock Margin="0,4,0,0" Text="{Binding Summary}" Foreground="#64748B" TextWrapping="Wrap" />
                                    </StackPanel>

                                    <Grid Grid.Row="2" Margin="0,18,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Padding="8,4" Background="#F8FAFC" CornerRadius="8" HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding TypeLabel}" Foreground="#334155" FontWeight="SemiBold" FontSize="12" />
                                        </Border>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Ellipse Width="8" Height="8" Fill="#4ADE80" Margin="0,0,6,0" />
                                            <TextBlock Text="Online" Foreground="#22C55E" FontSize="12" />
                                        </StackPanel>
                                    </Grid>

                                    <WrapPanel Grid.Row="3" Margin="0,20,0,0">
                                        <Button Margin="0,0,8,8"
                                                MinWidth="96"
                                                Command="{Binding DataContext.EditConnectionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                                Content="Editar" />
                                        <Button Margin="0,0,0,8"
                                                MinWidth="96"
                                                Command="{Binding DataContext.DeleteConnectionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                                Content="Eliminar" />
                                    </WrapPanel>
                                </Grid>
                            </materialDesign:Card>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <Border Background="#7A0F172A"
                Visibility="{Binding IsConnectionEditorOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <materialDesign:Card Width="560"
                                     MaxWidth="560"
                                     Margin="24"
                                     Padding="0"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     UniformCornerRadius="22"
                                     Background="White"
                                     materialDesign:ElevationAssist.Elevation="Dp4">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <DockPanel Margin="24,20,24,16">
                            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                <Border Width="38" Height="38" Background="#EEF2FF" CornerRadius="10">
                                    <materialDesign:PackIcon Kind="Plus"
                                                             Width="20"
                                                             Height="20"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center"
                                                             Foreground="{StaticResource PrimaryHueMidBrush}" />
                                </Border>
                                <StackPanel Margin="12,0,0,0">
                                    <TextBlock Text="Configurar Conexion A / B" FontSize="22" FontWeight="SemiBold" />
                                    <TextBlock Text="Completa los parametros y valida la conexion antes de guardar." Foreground="#64748B" />
                                </StackPanel>
                            </StackPanel>
                            <Button DockPanel.Dock="Right"
                                    Command="{Binding CloseConnectionEditorCommand}"
                                    Style="{StaticResource MaterialDesignToolButton}">
                                <materialDesign:PackIcon Kind="Close" />
                            </Button>
                        </DockPanel>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="24,0,24,24">
                                <TextBlock Text="{Binding ConnectionEditorTitle}" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock Margin="0,6,0,18" Text="Selecciona el tipo y luego completa solo los campos requeridos." Foreground="#64748B" TextWrapping="Wrap" />

                                <ComboBox SelectedValue="{Binding EditableConnection.Type}"
                                          SelectedValuePath="Tag"
                                          Style="{StaticResource MaterialDesignFilledComboBox}"
                                          materialDesign:HintAssist.Hint="Tipo de conexion"
                                          Margin="0,0,0,14">
                                    <ComboBoxItem Content="Selecciona un tipo" Tag="None" />
                                    <ComboBoxItem Content="Carpeta local" Tag="LocalFolder" />
                                    <ComboBoxItem Content="FTP" Tag="Ftp" />
                                    <ComboBoxItem Content="SFTP" Tag="Sftp" />
                                </ComboBox>

                                <TextBox Text="{Binding EditableConnection.Name}" Style="{StaticResource MaterialDesignFilledTextBox}" materialDesign:HintAssist.Hint="Nombre descriptivo" Margin="0,0,0,14" />

                                <Grid Visibility="{Binding IsLocalConnectionType, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBox Text="{Binding EditableConnection.Host}" Style="{StaticResource MaterialDesignFilledTextBox}" materialDesign:HintAssist.Hint="Ruta local" Margin="0,0,0,14" />
                                </Grid>

                                <Grid Visibility="{Binding IsRemoteConnectionType, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBox Grid.Row="0" Grid.Column="0" Margin="0,0,12,14" Text="{Binding EditableConnection.Host}" Style="{StaticResource MaterialDesignFilledTextBox}" materialDesign:HintAssist.Hint="Host o IP" />
                                    <TextBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,14" Text="{Binding EditableConnection.Port}" Style="{StaticResource MaterialDesignFilledTextBox}" materialDesign:HintAssist.Hint="Puerto" />
                                    <TextBox Grid.Row="1" Grid.ColumnSpan="2" Margin="0,0,0,14" Text="{Binding EditableConnection.Username}" Style="{StaticResource MaterialDesignFilledTextBox}" materialDesign:HintAssist.Hint="Usuario" />
                                    <TextBox Grid.Row="2" Grid.ColumnSpan="2" Margin="0,0,0,14" Text="{Binding EditableConnection.Password}" Style="{StaticResource MaterialDesignFilledTextBox}" materialDesign:HintAssist.Hint="Contrasena / token" />
                                    <TextBox Grid.Row="3" Grid.Column="0" Margin="0,0,12,14" Text="{Binding EditableConnection.TimeoutSeconds}" Style="{StaticResource MaterialDesignFilledTextBox}" materialDesign:HintAssist.Hint="Timeout (segundos)" />
                                    <TextBox Grid.Row="3" Grid.Column="1" Margin="0,0,0,14" Text="{Binding EditableConnection.RetryCount}" Style="{StaticResource MaterialDesignFilledTextBox}" materialDesign:HintAssist.Hint="Reintentos" />
                                </Grid>

                                <Grid Visibility="{Binding IsSftpConnectionType, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBox Grid.Row="0"
                                             Text="{Binding EditableConnection.PrivateKeyPath}"
                                             Style="{StaticResource MaterialDesignFilledTextBox}"
                                             materialDesign:HintAssist.Hint="Llave privada SFTP (.pem / .ppk)"
                                             Margin="0,0,0,14" />

                                    <TextBox Grid.Row="1"
                                             Text="{Binding EditableConnection.HostKeyFingerprint}"
                                             Style="{StaticResource MaterialDesignFilledTextBox}"
                                             materialDesign:HintAssist.Hint="Huella del host (ej. ssh-rsa 2048 77:5d:... o SHA256:...)"
                                             Margin="0,0,0,14" />
                                </Grid>

                                <CheckBox IsChecked="{Binding EditableConnection.IsEnabled}" Content="Conexion habilitada" Margin="0,0,0,8" />
                            </StackPanel>
                        </ScrollViewer>

                        <Border Grid.Row="2" Background="#F8FAFC" CornerRadius="0,0,22,22">
                            <WrapPanel Margin="24,18">
                                <Button Margin="0,0,12,8"
                                        MinWidth="170"
                                        Height="44"
                                        Command="{Binding TestConnectionCommand}"
                                        Style="{StaticResource MaterialDesignRaisedButton}"
                                        Background="{Binding TestConnectionButtonBackground}"
                                        Foreground="{Binding TestConnectionButtonForeground}"
                                        Content="{Binding TestConnectionButtonText}" />
                                <Button Margin="0,0,12,8"
                                        MinWidth="170"
                                        Height="44"
                                        Command="{Binding SaveConnectionCommand}"
                                        Style="{StaticResource MaterialDesignRaisedButton}"
                                        Content="Guardar Conexion" />
                                <Button Margin="0,0,0,8"
                                        MinWidth="120"
                                        Height="44"
                                        Command="{Binding CloseConnectionEditorCommand}"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        Content="Cerrar" />
                                <TextBlock Margin="0,4,0,0"
                                           Width="520"
                                           Text="{Binding TestConnectionStatusText}"
                                           Foreground="{Binding TestConnectionStatusForeground}"
                                           TextWrapping="Wrap" />
                            </WrapPanel>
                        </Border>
                    </Grid>
                </materialDesign:Card>
            </Grid>
        </Border>
    </Grid>
</UserControl>
