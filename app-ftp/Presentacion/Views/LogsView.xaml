<UserControl x:Class="app_ftp.Presentacion.Views.LogsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:controls="clr-namespace:app_ftp.Presentacion.Shared.Controls.DataTable"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <WrapPanel Margin="0,0,0,16">
            <materialDesign:Card Width="300" Margin="0,0,12,12" Padding="22" UniformCornerRadius="18" Background="White" materialDesign:ElevationAssist.Elevation="Dp2">
                <StackPanel>
                    <TextBlock Text="REGISTROS EXITOSOS" Foreground="#64748B" />
                    <TextBlock Margin="0,10,0,0" Text="{Binding SuccessCount}" FontSize="28" FontWeight="Bold" />
                </StackPanel>
            </materialDesign:Card>
            <materialDesign:Card Width="300" Margin="0,0,12,12" Padding="22" UniformCornerRadius="18" Background="White" materialDesign:ElevationAssist.Elevation="Dp2">
                <StackPanel>
                    <TextBlock Text="REGISTROS FALLIDOS" Foreground="#64748B" />
                    <TextBlock Margin="0,10,0,0" Text="{Binding FailedCount}" FontSize="28" FontWeight="Bold" Foreground="#DC2626" />
                </StackPanel>
            </materialDesign:Card>
            <materialDesign:Card Width="300" Margin="0,0,0,12" Padding="22" UniformCornerRadius="18" Background="White" materialDesign:ElevationAssist.Elevation="Dp2">
                <StackPanel>
                    <TextBlock Text="TRANSFERIDO TOTAL" Foreground="#64748B" />
                    <TextBlock Margin="0,10,0,0" Text="{Binding TotalTransferredText}" FontSize="28" FontWeight="Bold" />
                </StackPanel>
            </materialDesign:Card>
        </WrapPanel>

        <materialDesign:Card Grid.Row="1" Padding="24" UniformCornerRadius="18" Background="White" materialDesign:ElevationAssist.Elevation="Dp2">
            <StackPanel>
                <DockPanel Margin="0,0,0,16">
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="Registro de eventos" FontSize="24" FontWeight="SemiBold" />
                        <TextBlock Text="Monitorea ejecuciones, errores y volumen transferido." Foreground="#64748B" />
                    </StackPanel>                  
                </DockPanel>

                <controls:DataTableControl DataContext="{Binding TableViewModel}"
                                           ParentDataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                           Columns="{Binding DataContext.TableColumns, RelativeSource={RelativeSource AncestorType=UserControl}}" />
            </StackPanel>
        </materialDesign:Card>

        <Border Grid.RowSpan="2"
                Background="#990B1020"
                Visibility="{Binding IsLogDetailOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <materialDesign:Card Margin="16"
                                     Padding="0"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Stretch"
                                     MaxWidth="1100"
                                     MaxHeight="760"
                                     UniformCornerRadius="14"
                                     Background="White"
                                     materialDesign:ElevationAssist.Elevation="Dp4">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <DockPanel Margin="24,18,24,14" LastChildFill="False">
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Text="Detalle del Evento" FontSize="24" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding SelectedLog.Id, TargetNullValue=-}" Foreground="#64748B" />
                            </StackPanel>
                            <Button DockPanel.Dock="Right"
                                    Command="{Binding CloseLogDetailCommand}"
                                    Style="{StaticResource MaterialDesignToolButton}">
                                <materialDesign:PackIcon Kind="Close" />
                            </Button>
                        </DockPanel>

                        <Grid Grid.Row="1" Margin="24,0,24,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                                <WrapPanel Grid.Row="0" Margin="0,0,0,12">
                                    <Border Width="220" Padding="12" CornerRadius="10" Background="#F8FAFC" Margin="0,0,8,8">
                                        <StackPanel>
                                            <TextBlock Text="Estado" Foreground="#64748B" />
                                            <TextBlock Text="{Binding SelectedLog.Status, TargetNullValue=-}" FontWeight="Bold" FontSize="16" />
                                        </StackPanel>
                                    </Border>
                                    <Border Width="220" Padding="12" CornerRadius="10" Background="#F8FAFC" Margin="0,0,8,8">
                                        <StackPanel>
                                            <TextBlock Text="Operacion" Foreground="#64748B" />
                                            <TextBlock Text="{Binding SelectedLog.Operation, TargetNullValue=-}" FontWeight="SemiBold" />
                                        </StackPanel>
                                    </Border>
                                    <Border Width="220" Padding="12" CornerRadius="10" Background="#F8FAFC" Margin="0,0,8,8">
                                        <StackPanel>
                                            <TextBlock Text="Archivos" Foreground="#64748B" />
                                            <TextBlock Text="{Binding SelectedLog.FilesTransferred, TargetNullValue=0}" FontWeight="SemiBold" />
                                        </StackPanel>
                                    </Border>
                                    <Border Width="220" Padding="12" CornerRadius="10" Background="#F8FAFC" Margin="0,0,8,8">
                                        <StackPanel>
                                            <TextBlock Text="Fecha / Hora" Foreground="#64748B" />
                                            <TextBlock Text="{Binding SelectedLog.TimestampText, TargetNullValue=-}" FontWeight="SemiBold" />
                                        </StackPanel>
                                    </Border>
                                </WrapPanel>

                                <Border Grid.Row="1" Padding="12" CornerRadius="10" Background="#FFFDF5" BorderBrush="#F5E7A1" BorderThickness="1" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="Mensaje" Foreground="#8A6D1C" FontWeight="SemiBold" />
                                        <TextBlock Margin="0,8,0,0" Text="{Binding SelectedLog.Message, TargetNullValue=Sin mensaje disponible.}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="2" Padding="14" Background="#020617" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="10" MinHeight="100">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        
                                        <Grid Grid.Row="0" Margin="0,0,0,16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            
                                            <StackPanel>
                                                <TextBlock Text="DETALLE POR ARCHIVO"
                                                           Foreground="#93C5FD"
                                                           FontSize="13"
                                                           FontWeight="Bold"
                                                           FontFamily="Consolas" />
                                                <TextBlock Text="Traza completa de ejecución línea por línea"
                                                           Foreground="#94A3B8"
                                                           Margin="0,6,0,0"
                                                           FontSize="11" />
                                            </StackPanel>
                                            
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBox Text="{Binding DetailSearchText, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                         materialDesign:HintAssist.Hint="Filtrar en detalle"
                                                         Width="350"
                                                         Foreground="#E2E8F0"
                                                         BorderBrush="#475569"
                                                         materialDesign:HintAssist.Foreground="#94A3B8"
                                                         materialDesign:TextFieldAssist.HasClearButton="True"
                                                         VerticalAlignment="Center"
                                                         Margin="0,0,16,0" />

                                                <Button Command="{Binding OpenLogFileLocationCommand}"
                                                        ToolTip="Abrir ubicación del log"
                                                        IsEnabled="{Binding CanOpenLogFile}"
                                                        Foreground="#93C5FD"
                                                        Style="{StaticResource MaterialDesignToolButton}">
                                                    <materialDesign:PackIcon Kind="FolderOpen" Width="22" Height="22" />
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                        
                                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                                            <ScrollViewer.Resources>
                                                <Style TargetType="{x:Type ScrollBar}">
                                                    <Setter Property="Background" Value="#E5E7EB" />
                                                    <Setter Property="Foreground" Value="#9CA3AF" />
                                                    <Setter Property="Width" Value="10" />
                                                </Style>
                                                <Style TargetType="{x:Type Thumb}">
                                                    <Setter Property="Background" Value="#9CA3AF" />
                                                    <Setter Property="BorderBrush" Value="#9CA3AF" />
                                                </Style>
                                            </ScrollViewer.Resources>
                                            <TextBox Text="{Binding VisibleExecutionDetails, Mode=OneWay, TargetNullValue=Sin detalle disponible.}"
                                                     IsReadOnly="True"
                                                     BorderThickness="0"
                                                     Background="Transparent"
                                                     FontFamily="Consolas"
                                                     Foreground="#E2E8F0"
                                                     FontSize="12"
                                                     TextWrapping="NoWrap"
                                                     AcceptsReturn="True"
                                                     ScrollViewer.CanContentScroll="True" />
                                        </ScrollViewer>
                                    </Grid>
                                </Border>
                        </Grid>

                        <Border Grid.Row="2" Background="#F8FAFC" CornerRadius="0,0,14,14">
                            <WrapPanel Margin="24,14" HorizontalAlignment="Right">
                                <Button MinWidth="120"
                                        Height="40"
                                        Command="{Binding CloseLogDetailCommand}"
                                        Style="{StaticResource MaterialDesignRaisedButton}"
                                        Content="Cerrar" />
                            </WrapPanel>
                        </Border>
                    </Grid>
                </materialDesign:Card>
            </Grid>
        </Border>
    </Grid>
</UserControl>
