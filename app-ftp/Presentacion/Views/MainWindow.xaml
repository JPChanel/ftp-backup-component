<Window x:Class="app_ftp.Presentacion.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:app_ftp.Presentacion.Shared.Controls.Notifications"
        xmlns:views="clr-namespace:app_ftp.Presentacion.Views"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="BaaSService"
        Width="1220"
        Height="850"
        MinWidth="1080"
        MinHeight="760"
        Background="{StaticResource WindowBackgroundBrush}"
        TextElement.FontSize="14"
        TextElement.Foreground="#0F172A"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="16,14" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="MinHeight" Value="48" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#42526B" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="NavBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="18">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="NavBorder" Property="Background" Value="#F3F5FC" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="NavBorder" Property="Background" Value="#EAEEFA" />
                            </Trigger>
                            <Trigger Property="Tag" Value="True">
                                <Setter TargetName="NavBorder" Property="Background" Value="{StaticResource PrimaryHueMidBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavIconContainerStyle" TargetType="Border">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Background" Value="#F1F5F9" />
            <Setter Property="Margin" Value="0,0,12,0" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                    <Setter Property="Background" Value="#FFFFFF1F" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NavLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="SidebarModalBackdropStyle" TargetType="Border">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsAnyModalOpen}" Value="True">
                    <Setter Property="Effect">
                        <Setter.Value>
                            <BlurEffect Radius="8" />
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="222" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Style="{StaticResource SidebarModalBackdropStyle}"
                Background="{StaticResource SidebarBrush}"
                BorderBrush="{StaticResource AppPanelBorderBrush}"
                BorderThickness="0,0,1,0">
            <Grid Margin="18,20,18,18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="30"
                                Height="30"
                                Background="{StaticResource PrimaryHueMidBrush}"
                                CornerRadius="10">
                            <materialDesign:PackIcon Kind="CloudUploadOutline"
                                                     Width="16"
                                                     Height="16"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"
                                                     Foreground="White" />
                        </Border>
                        <StackPanel Margin="10,0,0,0"
                                    VerticalAlignment="Center">
                            <TextBlock FontSize="15"
                                       FontWeight="Bold">
                                <Run Text="BaaS" />
                                <Run Text="Service" Foreground="{StaticResource PrimaryHueMidBrush}" />
                            </TextBlock>
                            <TextBlock Text="Servicio Backup"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource SidebarMutedBrush}" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Row="1"
                            Margin="0,34,0,0">
                    <TextBlock Margin="6,0,0,12"
                               Text="NAVEGACION"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource SidebarMutedBrush}" />

                    <Button Style="{StaticResource NavButtonStyle}"
                            Command="{Binding ShowDashboardCommand}"
                            Tag="{Binding IsDashboardSelected}">
                        <StackPanel Orientation="Horizontal">
                            <Border Style="{StaticResource NavIconContainerStyle}">
                                <materialDesign:PackIcon Kind="PlayCircle"
                                                         Width="14"
                                                         Height="14"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center"
                                                         Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                            </Border>
                            <TextBlock Text="Ejecutar"
                                       Style="{StaticResource NavLabelStyle}" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource NavButtonStyle}"
                            Command="{Binding ShowConnectionsCommand}"
                            Tag="{Binding IsConnectionsSelected}">
                        <StackPanel Orientation="Horizontal">
                            <Border Style="{StaticResource NavIconContainerStyle}">
                                <materialDesign:PackIcon Kind="PowerPlug"
                                                         Width="14"
                                                         Height="14"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center"
                                                         Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                            </Border>
                            <TextBlock Text="Conexiones"
                                       Style="{StaticResource NavLabelStyle}" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource NavButtonStyle}"
                            Command="{Binding ShowLogsCommand}"
                            Tag="{Binding IsLogsSelected}">
                        <StackPanel Orientation="Horizontal">
                            <Border Style="{StaticResource NavIconContainerStyle}">
                                <materialDesign:PackIcon Kind="ChevronRight"
                                                         Width="14"
                                                         Height="14"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center"
                                                         Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                            </Border>
                            <TextBlock Text="Gestor de Logs"
                                       Style="{StaticResource NavLabelStyle}" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Row="2">
                    <Border Padding="18"
                            Background="{StaticResource SidebarSurfaceBrush}"
                            CornerRadius="24">
                        <StackPanel>
                            <TextBlock Text="Proteccion Local"
                                       FontWeight="SemiBold"
                                       Foreground="White" />
                            <TextBlock Margin="0,8,0,0"
                                       Text="Credenciales y configuraciones persisten cifradas en AppData."
                                       Foreground="{StaticResource SidebarTextBrush}"
                                       FontSize="11"
                                       TextWrapping="Wrap" />
                            <StackPanel Margin="0,14,0,0"
                                        Orientation="Horizontal">
                                <Ellipse Width="8"
                                         Height="8"
                                         Fill="#10B981"
                                         Margin="0,0,6,0" />
                                <TextBlock Text="Verificado"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="#86EFAC" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <StackPanel Margin="0,14,0,0"
                                HorizontalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding AppVersion}"
                                       FontSize="11"
                                       Foreground="{StaticResource SidebarMutedBrush}"
                                       VerticalAlignment="Center" />
                            <Button Margin="10,0,0,0"
                                    Height="28"
                                    Padding="10,0"
                                    FontSize="10"
                                    Style="{StaticResource AppPillButton}"
                                    Content="{Binding InstallUpdateButtonText}"
                                    Foreground="#16A34A"
                                    BorderBrush="#BBF7D0"
                                    Background="#F0FDF4"
                                    Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BooleanToVisibilityConverter}}"
                                    Command="{Binding InstallUpdateCommand}" />
                        </StackPanel>

                        <Border Margin="0,10,0,0"
                                Padding="12"
                                Background="#F8FAFF"
                                BorderBrush="{StaticResource AppPanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="16"
                                Visibility="{Binding IsUpdateProgressVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <DockPanel LastChildFill="False">
                                    <TextBlock Text="{Binding UpdateDownloadStatus}"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="#1E293B"
                                               TextWrapping="Wrap" />
                                    <TextBlock DockPanel.Dock="Right"
                                               Margin="10,0,0,0"
                                               Text="{Binding UpdateDownloadProgressText}"
                                               FontSize="11"
                                               Foreground="{StaticResource SidebarMutedBrush}" />
                                </DockPanel>
                                <ProgressBar Margin="0,10,0,0"
                                             Height="6"
                                             Minimum="0"
                                             Maximum="100"
                                             Value="{Binding UpdateDownloadProgress}"
                                             IsIndeterminate="{Binding IsUpdateProgressIndeterminate}"
                                             Foreground="{StaticResource PrimaryHueMidBrush}"
                                             Background="#E5E7EB" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>


        <Grid Grid.Column="1"
              Margin="32,28,30,26"
              PreviewMouseWheel="MainContentContainer_PreviewMouseWheel">
            <ScrollViewer x:Name="MainContentScrollViewer"
                          VerticalScrollBarVisibility="Hidden"
                          HorizontalScrollBarVisibility="Disabled"
                          CanContentScroll="True"
                          PanningMode="VerticalOnly">
                <Grid>
                    <ContentControl Visibility="{Binding IsDashboardVisible, Converter={StaticResource BooleanToVisibilityConverter}}" Content="{Binding Dashboard}">
                        <ContentControl.ContentTemplate>
                            <DataTemplate>
                                <views:DashboardView/>
                            </DataTemplate>
                        </ContentControl.ContentTemplate>
                    </ContentControl>

                    <ContentControl Visibility="{Binding IsConnectionsVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                                    Content="{Binding ConnectionsSection}">
                        <ContentControl.ContentTemplate>
                            <DataTemplate>
                                <views:ConnectionsView />
                            </DataTemplate>
                        </ContentControl.ContentTemplate>
                    </ContentControl>

                    <ContentControl Visibility="{Binding IsLogsVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                                    Content="{Binding LogsSection}">
                        <ContentControl.ContentTemplate>
                            <DataTemplate>
                                <views:LogsView />
                            </DataTemplate>
                        </ContentControl.ContentTemplate>
                    </ContentControl>
                </Grid>
            </ScrollViewer>
        </Grid>

        <controls:EstNotificationHost Grid.Column="1"
                                      Margin="0,0,24,24"
                                      Panel.ZIndex="20"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Bottom"
                                      AlertService="{Binding AlertService}" />
    </Grid>
</Window>
