<Window x:Class="app_ftp.Presentacion.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:config="clr-namespace:app_ftp.Config"
        xmlns:views="clr-namespace:app_ftp.Presentacion.Views"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="UtiBackup"
        Width="1000"
        Height="760"
        Background="{StaticResource SkyBackgroundBrush}"
        TextElement.FontSize="14"
        TextElement.Foreground="#0F172A"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="16,14" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="MinHeight" Value="52" />
            <Setter Property="Foreground" Value="{StaticResource SidebarSurfaceBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="NavBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="NavBorder" Property="Background" Value="#F3F6FF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="NavBorder" Property="Opacity" Value="0.9" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MetricCardStyle" TargetType="materialDesign:Card">
            <Setter Property="Margin" Value="0,0,16,16" />
            <Setter Property="Padding" Value="22" />
            <Setter Property="Background" Value="White" />
            <Setter Property="UniformCornerRadius" Value="18" />
            <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp2" />
        </Style>

        <Style x:Key="SectionCardStyle" TargetType="materialDesign:Card" BasedOn="{StaticResource MetricCardStyle}">
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="24" />
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="52" Height="52" CornerRadius="16" Background="{StaticResource PrimaryHueMidBrush}">
                            <materialDesign:PackIcon Kind="CloudUploadOutline"
                                                     Width="26"
                                                     Height="26"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"
                                                     Foreground="White" />
                        </Border>
                        <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="UtiBackup" FontSize="26" FontWeight="SemiBold"/>
                            <TextBlock Text="ENGINE CORE" FontFamily="Consolas" FontSize="12" Foreground="{StaticResource SidebarMutedBrush}" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,34,0,0">
                    <Button Style="{StaticResource NavButtonStyle}"
                            Command="{Binding ShowDashboardCommand}"
                            Background="{Binding DashboardButtonBackground}"
                            Foreground="{Binding DashboardButtonForeground}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ViewDashboardOutline"
                                                     Margin="0,0,10,0"
                                                     Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                            <TextBlock Text="Dashboard / Ejecutar"
                                       VerticalAlignment="Center"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButtonStyle}"
                            Command="{Binding ShowConnectionsCommand}"
                            Background="{Binding ConnectionsButtonBackground}"
                            Foreground="{Binding ConnectionsButtonForeground}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="LanConnect"
                                                     Margin="0,0,10,0"
                                                     Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                            <TextBlock Text="Conexiones A / B"
                                       VerticalAlignment="Center"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButtonStyle}"
                            Command="{Binding ShowLogsCommand}"
                            Background="{Binding LogsButtonBackground}"
                            Foreground="{Binding LogsButtonForeground}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="TextBoxSearchOutline"
                                                     Margin="0,0,10,0"
                                                     Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                            <TextBlock Text="Gestor de Logs"
                                       VerticalAlignment="Center"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                        </StackPanel>
                    </Button>
                    
                </StackPanel>

                <materialDesign:Card Grid.Row="2"
                                     Background="{StaticResource SidebarSurfaceBrush}"
                                     UniformCornerRadius="18"
                                     Padding="18"
                                     materialDesign:ElevationAssist.Elevation="Dp1">
                    <StackPanel>
                        <TextBlock Text="Proteccion local" FontWeight="SemiBold" Foreground="White" />
                        <TextBlock Margin="0,8,0,0"
                                   Text="Credenciales, configuraciones y logs persisten en AppData con proteccion local."
                                   Foreground="{StaticResource SidebarMutedBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </materialDesign:Card>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="20,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <materialDesign:Card Grid.Row="1"
                                 Margin="0,0,0,16"
                                 Padding="18,14"
                                 UniformCornerRadius="18"
                                 Background="{Binding StatusBannerBackground}"
                                 Visibility="{Binding HasStatusMessage, Converter={StaticResource BooleanToVisibilityConverter}}">
                <DockPanel LastChildFill="False">
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{Binding StatusBannerForeground}" FontWeight="SemiBold" />
                    <Button DockPanel.Dock="Right"
                            Command="{Binding ClearStatusCommand}"
                            Style="{StaticResource MaterialDesignToolButton}">
                        <materialDesign:PackIcon Kind="Close" Foreground="{Binding StatusBannerForeground}" />
                    </Button>
                </DockPanel>
            </materialDesign:Card>

            <Grid Grid.Row="2">
                <ScrollViewer VerticalScrollBarVisibility="Hidden"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="False"
                              Visibility="{Binding IsDashboardVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ContentControl Content="{Binding Dashboard}">
                        <ContentControl.ContentTemplate>
                            <DataTemplate>
                                <views:DashboardView />
                            </DataTemplate>
                        </ContentControl.ContentTemplate>
                    </ContentControl>
                </ScrollViewer>

                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="False"
                              Visibility="{Binding IsConnectionsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ContentControl Content="{Binding ConnectionsSection}">
                        <ContentControl.ContentTemplate>
                            <DataTemplate>
                                <views:ConnectionsView />
                            </DataTemplate>
                        </ContentControl.ContentTemplate>
                    </ContentControl>
                </ScrollViewer>

                <ContentControl Visibility="{Binding IsLogsVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                                Content="{Binding LogsSection}">
                    <ContentControl.ContentTemplate>
                        <DataTemplate>
                            <views:LogsView />
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>
            </Grid>
        </Grid>
    </Grid>
</Window>
